{
  "name": "inun-office-tools",
  "version": "1.0.0",
  "main": "out/main/main.js",
  "description": "文本文件处理工具 - 高效的批量文本处理工具箱",
  "author": "鲲穹AI",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win --config",
    "build:mac": "electron-vite build && electron-builder --mac --config",
    "preview": "electron-vite preview",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.kunqiong.ai.office.v3",
    "productName": "文本文件处理工具",
    "directories": {
      "output": "dist_102_v2"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "extraFiles": [
        {
          "from": "updater.exe",
          "to": "."
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "文本文件处理工具",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "artifactName": "wenben-mac-portable-${version}-universal.${ext}",
      "target": [
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  },
  "dependencies": {
    "@ant-design/icons": "^5.0.0",
    "@types/marked": "^5.0.2",
    "adm-zip": "^0.5.16",
    "antd": "^5.0.0",
    "chardet": "^2.0.0",
    "csv-parser": "^3.2.0",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "html-to-docx": "^1.8.0",
    "iconv-lite": "^0.6.3",
    "jspdf": "^4.0.0",
    "mammoth": "^1.11.0",
    "marked": "^17.0.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^25.0.0",
    "electron-builder": "^26.4.0",
    "electron-vite": "^1.0.0",
    "jsdom": "^27.4.0",
    "typescript": "^5.0.0",
    "vite": "^4.0.0",
    "vitest": "^1.0.0"
  }
}
